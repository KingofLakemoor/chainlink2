{
  "functions": {
    "predeploy": "npm run build",
    "source": ".",
    "runtime": "nodejs22",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "src/**",
      "scripts/**",
      "test-results/**",
      "public/**"
    ]
  },
  "firestore": {
    "rules": "firestore.rules", "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "predeploy": "npm run build",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/server.cjs"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
